      "entries": [
        {
          "threshold": 11016,
          "model": {
            "type": "minecraft:model",
            "model": "myrp:item/hades_shield"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:special",
        "model": { "type": "minecraft:shield" },
        "base": "minecraft:item/shield"
      }
    }
